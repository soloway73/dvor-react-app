<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Если файл или директория существуют - отдаём их
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Иначе перенаправляем на index.html
  RewriteRule ^ index.html [L]
</IfModule>

# Кэширование для статических ресурсов
<IfModule mod_expires.c>
  ExpiresActive On
  
  # HTML - не кэшировать
  ExpiresByType text/html "access plus 0 seconds"
  
  # JS и CSS - кэш на 1 день
  ExpiresByType application/javascript "access plus 1 day"
  ExpiresByType text/css "access plus 1 day"
  
  # HLS сегменты (.ts, .m4s) - короткое кэширование
  ExpiresByType video/mp2t "access plus 10 seconds"
  ExpiresByType application/octet-stream "access plus 10 seconds"
  
  # HLS плейлисты (.m3u8) - минимальное кэширование
  ExpiresByType application/vnd.apple.mpegurl "access plus 5 seconds"
  ExpiresByType application/x-mpegurl "access plus 5 seconds"
  
  # Изображения и шрифты - долгое кэширование
  ExpiresByType image/png "access plus 1 month"
  ExpiresByType image/jpeg "access plus 1 month"
  ExpiresByType image/gif "access plus 1 month"
  ExpiresByType image/svg+xml "access plus 1 month"
  ExpiresByType font/woff2 "access plus 1 month"
</IfModule>

# Заголовки кэширования
<IfModule mod_headers.c>
  # index.html - без кэша
  <FilesMatch "index\.html$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
    Header set Pragma "no-cache"
    Header set Expires 0
  </FilesMatch>
  
  # HLS плейлисты - минимальное кэширование
  <FilesMatch "\.(m3u8|ts|m4s)$">
    Header set Cache-Control "public, max-age=5, must-revalidate"
    Header set Access-Control-Allow-Origin "*"
  </FilesMatch>
  
  # Статические ресурсы - долгое кэширование
  <FilesMatch "\.(js|css|png|jpg|jpeg|gif|svg|woff2)$">
    Header set Cache-Control "public, max-age=86400, must-revalidate"
  </FilesMatch>
  
  # Сжатие для текстовых файлов
  <IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css application/javascript application/json
  </IfModule>
</IfModule>
